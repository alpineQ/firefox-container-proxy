{
  "manifest_version": 2,
  "name": "Container & Extension Proxy",
  "version": "0.2.3",
  "description": "__MSG_General_extensionDescription__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "container-proxy@alpineq.github.io",
      "strict_min_version": "91.1.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "browser_action": {
  },
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true,
    "browser_style": false
  },

  "permissions": [
    "<all_urls>",
    "webRequest",
    "webRequestBlocking",
    "storage",
    "contextualIdentities",
    "cookies",
    "proxy"
  ],

  "background": {
    "scripts": [
      "background/index.js"
    ]
  }

}
